# Porta da API REST
PORT=3001

# Caminho do arquivo do banco (padrao: ./hvac.db)
# DB_PATH=./hvac.db

# --- MQTT (recebe as leituras do ESP32) ---
MQTT_URL=mqtt://broker.hivemq.com:1883
MQTT_TOPIC=tcc-hvac-kaue/airquality
# Sala (id_sala) que recebe os dados do ESP
SALA_ID=1

# --- ntfy.sh (alertas) ---
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=tcc-hvac-alertas
NTFY_ENABLED=true
